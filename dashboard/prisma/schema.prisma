datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

/**
  Articles scheduled for posting on various platforms.
*/
model Article {
  id         String   @id @default(uuid())
  title      String
  content    String
  platforms  String[] // vk, tg, max, zen
  scheduleAt DateTime
  status     Status   @default(Planned)
  previewImg String?  // URL generated by rembrandt-designer
  postedAt   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum Status {
  Planned
  Ready
  Posted
}
