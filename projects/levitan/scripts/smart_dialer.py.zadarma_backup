MANGO_API_BASE = "https://app.mango-office.ru/vpbx/"
MANGO_FROM_EXTENSION = os.getenv("MANGO_FROM_EXTENSION", "22")

# Общее
OPENROUTER_KEY = os.getenv("OPENROUTER_API_KEY", "")
TELEGRAM_BOT_TOKEN = os.getenv("LEVITAN_TELEGRAM_BOT_TOKEN", "") or os.getenv("TELEGRAM_BOT_TOKEN", "")
TELEGRAM_CHAT_ID = os.getenv("LEVITAN_TELEGRAM_CHAT_ID", "") or os.getenv("TELEGRAM_CHAT_ID", "")

# VPS для STT
VPS_HOST = os.getenv("LEVITAN_VPS_HOST", "72.56.38.19")
VPS_USER = os.getenv("LEVITAN_VPS_USER", "root")

# Zadarma: записи приходят через webhook → хранятся локально на VPS
ZADARMA_RECORDS_DIR = Path(os.getenv("ZADARMA_RECORDS_DIR", "/var/log/levitan/zadarma_records"))
ZADARMA_EVENTS_PATH = Path(os.getenv("ZADARMA_EVENTS_PATH", "/var/log/levitan/zadarma_events.jsonl"))

# === ФИЛЬТР КУЛЬТУР ===
TARGET_KEYWORDS = [
    "зерновые", "пшеница", "ячмень", "кукуруза",
    "подсолнечник", "рапс", "соя",
    "горох", "нут", "чечевица",
