#!/usr/bin/env python3
"""
Levitan Smart Dialer — Автодозвон + автоCRM через запись.
=========================================================

Поддерживает две телефонии: Zadarma (рекомендуется) и Mango (legacy).
Управляется через TELEPHONY=zadarma|mango в .env.

Ты звонишь, говоришь с клиентом, кладёшь трубку.
Система автоматически:
1. Скачивает запись (Zadarma: прямой URL из webhook; Mango: API)
2. Транскрибирует на VPS (faster-whisper)
3. LLM извлекает: статус, культуры, объём, возражения...
4. Заполняет CRM (CSV + JSON)
5. Отправляет саммари в Telegram

Запуск: python3 scripts/smart_dialer.py
Тест:   python3 scripts/smart_dialer.py --test

Зависимости (локально): requests
Зависимости (VPS): faster-whisper, ffmpeg
"""

import csv
import hashlib
import json
import os
