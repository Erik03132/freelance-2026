# Levitan Environment Variables
# Скопируй в .env и заполни реальными значениями

# Mango Office
MANGO_API_KEY=your_mango_api_key
MANGO_SALT=your_mango_salt
MANGO_WEBHOOK_URL=https://your-server.com/mango/webhook
MANGO_SIP_USER=your_sip_user
MANGO_SIP_PASSWORD=your_sip_password
MANGO_SIP_HOST=vpbx400161137.mangosip.ru

# OpenRouter (LLM)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
OPENROUTER_FALLBACK_MODEL=qwen/qwen-2.5-7b-instruct

# Telegram (отчеты)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# STT (Speech-to-Text)
STT_MODEL_SIZE=base
STT_LANGUAGE=ru
STT_DEVICE=cpu

# TTS (Text-to-Speech)
TTS_VOICE=ru-RU-SvetlanaNeural
TTS_RATE=+0%

# Dialog
DIALOG_MAX_TURNS=20
DIALOG_SILENCE_TIMEOUT=5.0
DIALOG_MIN_SPEECH=0.3

# Campaign
CAMPAIGN_MAX_CONCURRENT=5
CAMPAIGN_RETRY_DELAYS=[15,60,180]
CAMPAIGN_CALL_HOURS_START=9
CAMPAIGN_CALL_HOURS_END=18
CAMPAIGN_MAX_RETRIES=3
