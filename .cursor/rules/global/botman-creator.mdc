### 4. Input Sanitization
```python
def sanitize_input(text: str, max_len: int = 4000) -> str:
    """Обрезка + очистка пользовательского ввода."""
    if not text:
        return ""
    text = text[:max_len]  # Лимит длины
    text = text.replace("\x00", "")  # Null bytes
    return text.strip()
```

### 5. Anti-Duplicate Lock (из Анжелочки)
```python
LOCK_FILE = os.path.join(LOG_DIR, "bot.lock")

def acquire_lock() -> bool:
    if os.path.exists(LOCK_FILE):
        try:
            with open(LOCK_FILE, 'r') as f:
                old_pid = int(f.read().strip())
            os.kill(old_pid, 0)  # Проверяем жив ли
            return False  # Жив — не запускаемся
        except (ProcessLookupError, ValueError):
            os.remove(LOCK_FILE)  # Stale lock
    with open(LOCK_FILE, 'w') as f:
        f.write(str(os.getpid()))
    return True
```

## ⚡ Graceful Lifecycle
> Дата: 2026-05-01 | Источник: боевой опыт Анжелочки

### Signal Handling + Cleanup
```python
import signal

async def main():
    if not acquire_lock():
        return

    loop = asyncio.get_event_loop()
    for sig in (signal.SIGTERM, signal.SIGINT):
        loop.add_signal_handler(sig, lambda: asyncio.create_task(shutdown()))
    
    await dp.start_polling(bot)
    release_lock()

async def shutdown():
    print("🛑 Graceful shutdown...")
    release_lock()
    await dp.stop_polling()
```

