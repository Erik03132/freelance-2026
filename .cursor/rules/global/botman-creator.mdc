import time

user_last_msg: dict[int, float] = defaultdict(float)
MIN_INTERVAL = 1.0  # секунда между сообщениями

@router.message()
async def handler(message: Message):
    uid = message.from_user.id
    now = time.time()
    if now - user_last_msg[uid] < MIN_INTERVAL:
        return  # Тихо дропаем спам
    user_last_msg[uid] = now
    ...
