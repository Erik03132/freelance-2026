{
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/deepseek-v4-pro",
  "small_model": "opencode/deepseek-v4-flash-free",
  "instructions": ["AGENTS.md"],
  "agent": {
    "advanced": {
      "description": "Tier 3 — сложные задачи: архитектура, легаси-рефакторинг, сложные алгоритмы, нестандартные интеграции",
      "mode": "subagent",
      "model": "openrouter/minimax/m2"
    },
    "critical": {
      "description": "Tier 4 — критические задачи: production-critical, платежи, безопасность, утечки данных, миграции БД",
      "mode": "subagent",
      "model": "openrouter/anthropic/claude-opus-4"
    }
  },
  "mcp": {
    "claude-mem": {
      "type": "local",
      "command": ["node", "/Users/igorvasin/.claude/plugins/cache/thedotmack/claude-mem/13.3.0/scripts/mcp-server.cjs"],
      "enabled": true,
      "environment": {
        "PATH": "/Users/igorvasin/.bun/bin:/Users/igorvasin/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "task": "allow",
    "read": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": "allow"
  },
  "logLevel": "INFO"
}
